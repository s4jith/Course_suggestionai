# ============================================================
# Application Settings
# ============================================================
APP_NAME="Academic Lesson Plan API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="AI-powered academic lesson plan management system"
DEBUG=false
ENVIRONMENT=production        # development | staging | production

# ============================================================
# API
# ============================================================
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]

# ============================================================
# MongoDB
# ============================================================
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=lesson_plan_db

# ============================================================
# JWT Authentication
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=<your-strong-random-secret-here>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# Password Hashing
# ============================================================
BCRYPT_ROUNDS=12

# ============================================================
# Ollama AI Engine
# ============================================================
# Ollama must be running locally: https://ollama.com/download
# Pull the model first: ollama pull mistral:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=60
OLLAMA_ENABLED=true
